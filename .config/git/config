

[user]
    name = Ahmad Ziad Zain Aldeen


[core]
    compression  = 9
    whitespace   = error
    preloadindex = true


[url "https://github.com/LazieKat/"]
    insteadof = "lk:"


[url "https://github.com/"]
    insteadof = "gh:"


[init]
    defaultBranch = main


[pager]
    diff = diff-so-fancy | $PAGER


[diff-so-fancy]
    markEmptyLines = false


[log]
    abbrevCommit = true
    graphColors  = blue, yellow, cyan, magenta, green, red


[color "decorate"]
    HEAD   = red
    branch = blue
    tag    = yellow
    remoteBranch = magenta


[branch]
    sort = -committerdate


[tag]
    sort = -taggerdate
